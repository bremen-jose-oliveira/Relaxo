EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# --- Cloud schema CLI (npm run db:supabase / :fresh / :new) ---
# Check without DB login: npm run db:supabase:status
#
# Option A (recommended): paste Session mode URI from
#   Supabase → Project Settings → Database → Connect → Session mode
# SUPABASE_DB_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
#
# Option B: password + region (region = middle of pooler host aws-0-<region>.pooler…)
# SUPABASE_DB_PASSWORD=YOUR_DATABASE_PASSWORD
# SUPABASE_DB_REGION=eu-central-1
